SERVICE_NAME=ride-service
NODE_ENV=development
PORT=3003
LOG_LEVEL=info

# PostgreSQL
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/cab_booking
DB_HOST=localhost
DB_PORT=5432
DB_NAME=cab_booking
DB_USER=postgres
DB_PASSWORD=postgres
DB_SSL=false

# Kafka
KAFKA_BROKERS=localhost:9092
KAFKA_CLIENT_ID=ride-service
KAFKA_GROUP_ID=ride-service-group

# Redis
REDIS_URL=redis://localhost:6379

# Rate limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=100

# Payload
MAX_PAYLOAD_SIZE=1mb
