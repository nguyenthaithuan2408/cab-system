NODE_ENV=development
PORT=3000

# To run proper HTTPS locally, you need self-signed certs. If omitted, it falls back to HTTP.
SSL_KEY_PATH=./certs/server.key
SSL_CERT_PATH=./certs/server.crt

# Secret for decoding JWT Token at API Gateway to enforce RBAC/ABAC
JWT_SECRET=your_super_secret_jwt_key_here

# Services Host URLs
AUTH_SERVICE_URL=http://localhost:3001
BOOKING_SERVICE_URL=http://localhost:3002
RIDE_SERVICE_URL=http://localhost:3003
PRICING_SERVICE_URL=http://localhost:3004
PAYMENT_SERVICE_URL=http://localhost:3005
