SERVICE_NAME=booking-service
NODE_ENV=development
PORT=3002
LOG_LEVEL=info

# PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_NAME=booking_service_db
DB_USER=postgres
DB_PASSWORD=postgres
DB_SSL=false
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/cab_booking

# Kafka
KAFKA_BROKERS=localhost:9092
KAFKA_CLIENT_ID=booking-service
KAFKA_GROUP_ID=booking-service-group

# Redis (dùng cho idempotency cache)
REDIS_URL=redis://localhost:6379

# JWT
JWT_SECRET=your-jwt-secret-here
JWT_PUBLIC_KEY=

# Internal Service URLs (để gọi Pricing Service)
PRICING_SERVICE_URL=http://localhost:3004
DRIVER_SERVICE_URL=http://localhost:3007

# Rate Limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=100

# Payload size limit
MAX_PAYLOAD_SIZE=1mb
