# ─── Application ─────────────────────────────────────────────────────────────

# Port the HTTP server listens on
PORT=3001

# Node environment: "development" | "production" | "test"
NODE_ENV=development

# ─── Database ─────────────────────────────────────────────────────────────────

# PostgreSQL connection string (required)
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=SCHEMA
DATABASE_URL="postgresql://cab_admin:cab_password@localhost:5432/cab_booking?schema=public"

# ─── Cache ────────────────────────────────────────────────────────────────────

# Redis connection string (required)
REDIS_URL="redis://localhost:6379"

# ─── JWT Secrets ──────────────────────────────────────────────────────────────

# ⚠️  Use strong random strings in production (min 32 chars / 256-bit entropy).
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"

# Access token signing secret (required)
JWT_ACCESS_SECRET="replace_with_strong_random_secret_min_32_chars"

# Refresh token signing secret (required) — must be DIFFERENT from access secret
JWT_REFRESH_SECRET="replace_with_another_strong_random_secret_min_32_chars"

# ─── Kafka ────────────────────────────────────────────────────────────────────

# Comma-separated list of Kafka broker addresses
KAFKA_BROKERS="localhost:9092"

# ─── CORS ─────────────────────────────────────────────────────────────────────

# Comma-separated list of allowed origins (Zero Trust: explicit allowlist).
# Leave empty to allow all origins in development.
CORS_ORIGINS="http://localhost:3000,http://localhost:5173"

# ─── Logging ──────────────────────────────────────────────────────────────────

# Pino log level: trace | debug | info | warn | error | fatal
LOG_LEVEL="info"
